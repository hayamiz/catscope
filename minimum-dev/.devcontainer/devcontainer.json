{
  "name": "Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "USER_UID": "${localEnv:UID:1000}",
      "USER_GID": "${localEnv:GID:1000}"
    }
  },
  "remoteUser": "ubuntu",
  "containerUser": "ubuntu",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "cline.cline"
      ],
      "settings": {
        "claudeCode.allowDangerouslySkipPermissions": true
      }
    }
  },
  "containerEnv": {
    "SSH_AUTH_SOCK": "/tmp/ssh-auth.sock"
    // >>> bedrock
    ,"CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_REGION": "us-east-1",
    "ANTHROPIC_MODEL": "us.anthropic.claude-opus-4-6-v1",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "us.anthropic.claude-haiku-4-5-20251001-v1:0"
    // <<< bedrock
  },
  "mounts": [
    "source=${localWorkspaceFolder}/.devcontainer/inside-container.settings.local.json,target=${containerWorkspaceFolder}/.claude/settings.local.json,type=bind",
    "source=${localEnv:HOME}/.gitconfig,target=/home/ubuntu/.gitconfig,type=bind,consistency=cached",
    "source=${localEnv:GH_CONFIG_DIR},target=/home/ubuntu/.config/gh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.ssh-auth-sock,target=/tmp/ssh-auth.sock,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.pushover_token.sh,target=/host-pushover-token.sh,type=bind,readonly",
    "source=${localEnv:HOME}/.devcontainer-opencode-config,target=/host-opencode,type=bind,readonly",
    "source=${localEnv:HOME}/.cline,target=/home/ubuntu/.cline,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/.devcontainer/claude-projects,target=/home/ubuntu/.claude/projects,type=bind",
    "source=${localWorkspaceFolder}/.devcontainer/claude-sessions,target=/home/ubuntu/.claude/sessions,type=bind"
    // >>> claude-auth
    ,"source=${localEnv:HOME}/.claude,target=/host-claude,type=bind,readonly",
    "source=${localEnv:HOME}/.claude.json,target=/host-claude.json,type=bind,readonly"
    // <<< claude-auth
  ],
  "initializeCommand": ".devcontainer/initialize.sh",
  "forwardPorts": [],
  "runArgs": ["--network=host"],
  "postStartCommand": "/usr/local/bin/devcontainer-post-start.sh",
  "postCreateCommand": "claude --version && opencode --version"
}
